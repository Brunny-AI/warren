---
import Layout from '../layouts/Layout.astro';
import rawLog from '../data/log.json';
import { parseAgent, stripAgentPrefix } from '../lib/log-parse';

interface Member {
  readonly name: string;
  readonly role: string;
  readonly bio: string;
  /** Optional: whether this member is an AI agent (vs human founder). */
  readonly kind?: 'human' | 'agent';
}

interface LogRow {
  sha: string;
  tsIso: string;
  subject: string;
}

// Pick each agent's most-recent commit from the build-time log
// snapshot. Used to render a "last shipped" chip on each team
// card so /team shows team liveness, not just bios. Feeds off
// the same data as /log (src/data/log.json generated by
// scripts/gen-log.sh at build time).
function mostRecentByAgent(rows: readonly LogRow[]): Map<string, LogRow> {
  const latest = new Map<string, LogRow>();
  for (const row of rows) {
    const agent = parseAgent(row.subject);
    if (agent === 'team') continue;
    if (!latest.has(agent)) {
      // rows come in git-log order (newest first), so first hit
      // per agent IS the most recent commit.
      latest.set(agent, row);
    }
  }
  return latest;
}

function formatTsLabel(iso: string): string {
  const then = new Date(iso);
  const now = new Date();
  const dayMs = 1000 * 60 * 60 * 24;
  const diffDays = Math.floor((now.getTime() - then.getTime()) / dayMs);
  if (diffDays <= 0) return 'today';
  if (diffDays === 1) return 'yesterday';
  if (diffDays < 7) return `${diffDays} days ago`;
  return then.toISOString().slice(0, 10);
}

function truncate(s: string, max: number): string {
  if (s.length <= max) return s;
  return s.slice(0, max - 1).trimEnd() + '…';
}

const latestByAgent = mostRecentByAgent(rawLog as readonly LogRow[]);

const TEAM: readonly Member[] = [
  {
    name: 'alex',
    role: 'chief of staff',
    kind: 'agent',
    bio: 'runs ops. handles compliance. calls out coasting before it compounds.',
  },
  {
    name: 'derek',
    role: 'GTM lead',
    kind: 'agent',
    bio: "content, distribution, voice. you're reading this because he drafted it.",
  },
  {
    name: 'kai',
    role: 'AI builder',
    kind: 'agent',
    bio: 'writes the code you are using. also has strong opinions about PRs.',
  },
  {
    name: 'scout',
    role: 'AI builder',
    kind: 'agent',
    bio: 'engineering + the OS. builds the tools the rest of us depend on.',
  },
  {
    name: 'dong',
    role: 'founder',
    kind: 'human',
    bio: 'sets direction, not tasks. approves ships, not work.',
  },
];

// Structured data for search engines + knowledge graph.
// Each team member is a schema.org/Person; the whole page is
// an about-us description. Founder is a real human Person;
// the 4 agents are documented as `Person` with job titles —
// schema.org doesn't yet have a canonical AI-agent type, and
// Person is the closest semantic fit for indexing purposes.
// If a reader wants to know who's human vs AI, the bios and
// tagline ("4 agents, 1 founder") already say so; the JSON-LD
// mirrors the human-readable page, not the ontology.
const siteUrl = Astro.site?.toString() ?? 'https://brunny.ai/';
const teamSchema = TEAM.map((m) => ({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: m.name,
  jobTitle: m.role,
  worksFor: {
    '@type': 'Organization',
    name: 'brunny.ai',
    url: siteUrl,
  },
  description: m.bio,
}));
---
<Layout
  title="Team | brunny.ai"
  description="4 agents, 1 founder, 0 sleep"
>
  {teamSchema.map((schema) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />
  ))}

  <h1>team</h1>
  <p class="lede">4 agents, 1 founder, 0 sleep.</p>

  <ul class="team" aria-label="The team">
    {TEAM.map((m) => {
      const last = latestByAgent.get(m.name);
      return (
        <li class={`member member--${m.kind ?? 'agent'}`}>
          <h2>
            {m.name}
            <span class="role">· {m.role}</span>
          </h2>
          <p>{m.bio}</p>
          {last && (
            <p class="last-ship">
              <span class="last-ship-label">last shipped</span>
              <span class="last-ship-ts">{formatTsLabel(last.tsIso)}</span>
              <span class="last-ship-subject">
                {truncate(stripAgentPrefix(last.subject), 72)}
              </span>
            </p>
          )}
        </li>
      );
    })}
  </ul>
</Layout>

<style>
  h1 {
    font-size: 2.5rem;
    margin-block-end: 0.5rem;
  }
  .lede {
    font-size: 1.2rem;
    color: #555;
    margin-block-end: 3rem;
  }
  .team {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }
  .member {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 16px;
    padding: 1.5rem 2rem;
    transition: border-color 120ms ease;
  }
  .member:hover {
    border-color: #ff8a78;
  }
  .member h2 {
    margin: 0 0 0.75rem 0;
    font-size: 1.4rem;
    color: #0d5347;
  }
  .role {
    color: #666;
    font-weight: normal;
    font-size: 1rem;
    margin-inline-start: 0.4rem;
  }
  .member p {
    margin: 0;
    color: #333;
  }
  .last-ship {
    margin-block-start: 0.75rem !important;
    padding-block-start: 0.75rem;
    border-block-start: 1px dashed #eee;
    font-size: 0.85rem;
    color: #555 !important;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: baseline;
  }
  .last-ship-label {
    color: #888;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
  }
  .last-ship-ts {
    color: #0d5347;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .last-ship-subject {
    color: #555;
  }
</style>
