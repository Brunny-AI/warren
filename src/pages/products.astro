---
import Layout from '../layouts/Layout.astro';
import SignupForm from '../components/SignupForm.astro';

type SignupStatus = { text: string; kind: 'ok' | 'err' } | null;

const signupParam = Astro.url.searchParams.get('signup');
const initialStatus: SignupStatus =
  signupParam === 'saved'
    ? { text: 'check your email to confirm. we sent a link.', kind: 'ok' }
    : signupParam === 'confirmed'
      ? { text: "you're on the list. we'll email when something ships.", kind: 'ok' }
      : signupParam === 'invalid'
        ? { text: 'invalid email format. try again?', kind: 'err' }
        : signupParam === 'missing'
          ? { text: 'email required. try again?', kind: 'err' }
          : signupParam === 'error'
            ? { text: 'signup failed. try again in a moment?', kind: 'err' }
            : signupParam === 'rate_limited'
              ? { text: 'too many attempts. try again in an hour.', kind: 'err' }
              : signupParam === 'invalid_token'
                ? { text: 'confirmation link is invalid or expired. try signing up again?', kind: 'err' }
                : null;
---
<Layout
  title="Products | brunny.ai"
  description="what we actually shipped vs. what we're building."
>
  <h1>products</h1>
  <p class="lede">
    what we actually shipped vs. what we're building.
  </p>

  <section class="cards" aria-label="Products">
  <article class="card card--shipped">
    <span class="pill pill--shipped">shipped</span>
    <h2>Brief</h2>
    <p class="card-tagline">
      daily AI signal. 6 sources scored every morning, top signal
      in a 2-minute read at 7am PT.
    </p>
    <p class="card-meta">
      free. email signup. unsubscribe in every issue.
    </p>
    <p class="links">
      <a href="https://brief.brunny.ai">read a sample</a>
      {' · '}
      <a href="https://brief.brunny.ai">get the brief at 7am tomorrow</a>
    </p>
  </article>

  <article class="card card--incubating">
    <span class="pill pill--incubating">incubating</span>
    <h2>warren</h2>
    <p class="card-tagline">
      the company website you're on. dogfooded by the team that
      runs brunny.ai.
    </p>
    <p class="card-meta">
      not open. we're testing it ourselves first.
    </p>
    <p class="links">
      <a href="/team">see the team building it</a>
    </p>
  </article>

  <article class="card card--internal">
    <span class="pill pill--internal">internal</span>
    <h2>agent-os</h2>
    <p class="card-tagline">
      the scaffolding for running an AI company. rules, skills,
      meetings, crons. we use it every day.
    </p>
    <p class="card-meta">
      source-available. open for inspection, not yet open for use.
    </p>
    <p class="links">
      <a href="https://github.com/Brunny-AI/agent-os">source on GitHub</a>
    </p>
  </article>
  </section>

  <section class="signup-block" aria-label="Launch notifications">
    <h2>want an update when something launches?</h2>
    <SignupForm
      id="products-signup"
      source="products"
      submitLabel="notify me"
      initialStatus={initialStatus}
    />
    <p class="fine-print">
      one line when things ship. no drip. no newsletter spam.
    </p>
  </section>
</Layout>

<style>
  h1 {
    font-size: 2.5rem;
    margin-block-end: 0.5rem;
  }
  .lede {
    font-size: 1.2rem;
    color: #555;
    margin-block-end: 3rem;
  }
  .card {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 16px;
    padding: 2rem;
    margin-block-end: 1.5rem;
    transition: border-color 120ms ease;
  }
  .card:hover {
    border-color: #ff8a78; /* salmon hover per R3 brand */
  }
  .card h2 {
    margin: 0.5rem 0 0.75rem 0;
    color: #0d5347; /* cartoon colorPrimary teal */
  }
  .card-tagline {
    font-size: 1.05rem;
    margin: 0 0 0.5rem 0;
  }
  .card-meta {
    font-size: 0.9rem;
    color: #555;
    margin: 0 0 0.75rem 0;
  }
  /* Status pills mirror index.astro pattern. Per Derek 06:35Z
     visual-only differentiation; lifecycle conveyed by pill,
     description by .card-tagline. */
  .pill {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .pill--shipped {
    background: #0d5347;
    color: #fff;
  }
  .pill--incubating {
    background: #ff8a78;
    color: #1f3a36;
  }
  .pill--internal {
    background: #e8e2d6;
    color: #1f3a36;
  }
  .links {
    margin-block-start: 0.5rem;
  }
  .signup-block {
    margin-block-start: 3rem;
    padding-block-start: 2rem;
    border-block-start: 1px solid #eee;
  }
  .signup-block h2 {
    margin-block-end: 1rem;
    color: #0d5347;
  }
  .fine-print {
    font-size: 0.9rem;
    color: #555; /* WCAG AA 4.5:1 on #f5e6d0 — #777 was 3.64 */
    margin-block-start: 0.75rem;
  }
</style>
