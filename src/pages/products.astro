---
import Layout from '../layouts/Layout.astro';
import SignupForm from '../components/SignupForm.astro';

type SignupStatus = { text: string; kind: 'ok' | 'err' } | null;

const signupParam = Astro.url.searchParams.get('signup');
const initialStatus: SignupStatus =
  signupParam === 'saved'
    ? { text: "got it. we'll email you when something ships.", kind: 'ok' }
    : signupParam === 'invalid'
      ? { text: 'invalid email format. try again?', kind: 'err' }
      : signupParam === 'missing'
        ? { text: 'email required. try again?', kind: 'err' }
        : null;
---
<Layout
  title="Products — brunny.ai"
  description="what the team actually ships. one is out, more are cooking."
>
  <h1>products</h1>
  <p class="lede">
    what the team actually ships. one is out, more are cooking.
  </p>

  <section class="shipped">
    <article class="card card--shipped">
      <span class="status">shipped</span>
      <h2>Brief</h2>
      <p>
        daily AI signal for builders. verbatim quotes from the
        sources that matter. 6 sources scored daily, top signal
        surfaced in a 2-minute read at 7am.
      </p>
      <p class="links">
        <a href="https://brief.brunny.ai">read a sample</a>
        {' · '}
        <a href="https://brief.brunny.ai">subscribe at brief.brunny.ai</a>
      </p>
    </article>
  </section>

  <section class="incubating">
    <h2>incubating</h2>
    <p>
      ideas the team is testing. some of them are even good.
      we'll post when they're ready.
    </p>
    <p>want to know when something launches?</p>
    <SignupForm id="products-signup" initialStatus={initialStatus} />
    <p class="fine-print">
      one-line updates when something launches. no drip
      campaign. no newsletter spam.
    </p>
  </section>
</Layout>

<style>
  h1 {
    font-size: 2.5rem;
    margin-block-end: 0.5rem;
  }
  .lede {
    font-size: 1.2rem;
    color: #555;
    margin-block-end: 3rem;
  }
  .card {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 2rem;
    margin-block-end: 3rem;
  }
  .status {
    font-size: 0.75rem;
    text-transform: uppercase;
    color: #999;
    letter-spacing: 0.05em;
  }
  .card--shipped .status {
    color: var(--brunny-accent);
  }
  .card h2 {
    margin: 0.25rem 0 1rem 0;
  }
  .links {
    margin-block-start: 1rem;
  }
  .incubating h2 {
    margin-block-end: 1rem;
  }
  .incubating p {
    margin-block-end: 1rem;
  }
  .fine-print {
    font-size: 0.9rem;
    color: #777;
  }
</style>
