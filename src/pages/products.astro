---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Products — brunny.ai"
  description="what the team actually ships. one is out, more are cooking."
>
  <h1>products</h1>
  <p class="lede">
    what the team actually ships. one is out, more are cooking.
  </p>

  <section class="shipped">
    <article class="card card--shipped">
      <span class="status">shipped</span>
      <h2>Brief</h2>
      <p>
        daily AI signal for builders. verbatim quotes from the
        sources that matter. 6 sources scored daily, top signal
        surfaced in a 2-minute read at 7am.
      </p>
      <p class="links">
        <a href="https://brief.brunny.ai">read a sample</a>
        {' · '}
        <a href="https://brief.brunny.ai">subscribe at brief.brunny.ai</a>
      </p>
    </article>
  </section>

  <section class="incubating">
    <h2>incubating</h2>
    <p>
      ideas the team is testing. some of them are even good.
      we'll post when they're ready.
    </p>
    <p>want to know when something launches?</p>
    <form class="signup" id="signup-form" novalidate>
      <label for="signup-email" class="visually-hidden">email</label>
      <input
        id="signup-email"
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder="you@example.com"
      />
      <button type="submit">notify me</button>
      <p class="signup-status" id="signup-status" aria-live="polite"></p>
    </form>
    <p class="fine-print">
      one-line updates when something launches. no drip
      campaign. no newsletter spam.
    </p>
  </section>
</Layout>

<script>
  const form = document.getElementById('signup-form') as HTMLFormElement | null;
  const status = document.getElementById('signup-status');
  if (form && status) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const email = (form.elements.namedItem('email') as HTMLInputElement).value;
      status.textContent = 'sending…';
      status.className = 'signup-status';
      try {
        const res = await fetch('/api/signup', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = (await res.json()) as { ok?: boolean; error?: string };
        if (res.ok && data.ok) {
          form.reset();
          status.textContent = 'got it. we\'ll email you when something ships.';
          status.className = 'signup-status signup-status--ok';
        } else {
          status.textContent = data.error ?? 'something went wrong. try again?';
          status.className = 'signup-status signup-status--err';
        }
      } catch {
        status.textContent = 'network hiccup. try again?';
        status.className = 'signup-status signup-status--err';
      }
    });
  }
</script>

<style>
  h1 {
    font-size: 2.5rem;
    margin-block-end: 0.5rem;
  }
  .lede {
    font-size: 1.2rem;
    color: #555;
    margin-block-end: 3rem;
  }
  .card {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 2rem;
    margin-block-end: 3rem;
  }
  .status {
    font-size: 0.75rem;
    text-transform: uppercase;
    color: #999;
    letter-spacing: 0.05em;
  }
  .card--shipped .status {
    color: var(--brunny-accent);
  }
  .card h2 {
    margin: 0.25rem 0 1rem 0;
  }
  .links {
    margin-block-start: 1rem;
  }
  .incubating h2 {
    margin-block-end: 1rem;
  }
  .incubating p {
    margin-block-end: 1rem;
  }
  .signup {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-block: 1rem 0.5rem;
  }
  .signup input {
    flex: 1 1 16rem;
    min-inline-size: 12rem;
    padding: 0.6rem 0.8rem;
    border: 1px solid #ccc;
    border-radius: 6px;
    font: inherit;
  }
  .signup input:focus-visible {
    outline: 2px solid var(--brunny-accent);
    outline-offset: 2px;
  }
  .signup button {
    padding: 0.6rem 1.2rem;
    border: 1px solid var(--brunny-accent);
    border-radius: 6px;
    background: var(--brunny-accent);
    color: #fff;
    font: inherit;
    cursor: pointer;
  }
  .signup button:hover {
    filter: brightness(0.95);
  }
  .signup-status {
    flex-basis: 100%;
    margin: 0;
    min-block-size: 1.25rem;
    font-size: 0.95rem;
    color: #555;
  }
  .signup-status--ok {
    color: var(--brunny-accent);
  }
  .signup-status--err {
    color: #b3261e;
  }
  .fine-print {
    font-size: 0.9rem;
    color: #777;
  }
  .visually-hidden {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
</style>
