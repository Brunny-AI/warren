---
// /log — warren changelog rendered from a build-time git-log
// snapshot.
//
// scripts/gen-log.sh runs BEFORE `astro build` (wired via the
// package.json build script) and writes src/data/log.json. This
// page imports that JSON, so no node:child_process lives inside
// the Cloudflare Worker bundle at runtime.
//
// Prerendered so the page is cacheable at the edge and doesn't
// pay a Worker request for a static changelog. SSR is reserved
// for the signup API routes that need request-time state.
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import rawLog from '../data/log.json';
//
// The "live feed: coming soon" framing still applies — this is
// the SHIPPED changelog, not the live bus. A visitor sees what
// merged today, scoped to warren. Bold idea #2 (full bus
// viewer with privacy pipeline) lands later.

type Agent = 'alex' | 'derek' | 'kai' | 'scout' | 'founder' | 'team';

interface LogEntry {
  readonly sha: string;
  readonly agent: Agent;
  readonly tsIso: string;
  readonly tsLabel: string;
  readonly body: string;
}

const AGENT_ROLES: Record<Agent, string> = {
  alex: 'chief of staff',
  derek: 'GTM lead',
  kai: 'AI builder',
  scout: 'AI builder',
  founder: 'founder',
  team: 'team',
};

function parseAgent(subject: string): Agent {
  const m = subject.match(/^\[([a-z]+)\]/i);
  if (!m) return 'team';
  const raw = m[1].toLowerCase();
  if (raw === 'alex' || raw === 'derek' || raw === 'kai' || raw === 'scout' || raw === 'founder') {
    return raw;
  }
  return 'team';
}

function stripAgentPrefix(subject: string): string {
  return subject.replace(/^\[[a-z]+\]\s*/i, '');
}

function formatTsLabel(iso: string): string {
  // Collapse to "today" / "yesterday" / "N days ago" relative
  // to build time. Build-time-static is acceptable because the
  // page re-renders on every deploy; the label becomes stale
  // only between deploys, which is the same cadence as the
  // content itself.
  const then = new Date(iso);
  const now = new Date();
  const dayMs = 1000 * 60 * 60 * 24;
  const diffDays = Math.floor(
    (now.getTime() - then.getTime()) / dayMs,
  );
  const hhmm = then.toLocaleTimeString('en-US', {
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
    timeZone: 'America/Los_Angeles',
  });
  if (diffDays <= 0) return `today, ${hhmm} PT`;
  if (diffDays === 1) return `yesterday, ${hhmm} PT`;
  if (diffDays < 7) return `${diffDays} days ago`;
  return then.toISOString().slice(0, 10);
}

interface RawLogRow {
  sha: string;
  tsIso: string;
  subject: string;
}

const entries: LogEntry[] = (rawLog as readonly RawLogRow[]).map((row) => ({
  sha: row.sha,
  agent: parseAgent(row.subject),
  tsIso: row.tsIso,
  tsLabel: formatTsLabel(row.tsIso),
  body: stripAgentPrefix(row.subject),
}));
---
<Layout
  title="log | brunny.ai"
  description="see what the agents just shipped. rendered from warren's git log at deploy time."
>
  <h1>log</h1>
  <p class="lede">
    see what the agents just shipped. rendered from warren's git
    log at every deploy.
  </p>

  <section class="live-soon" aria-label="Live feed status">
    <p class="note">
      <strong>shipped log.</strong> every entry below is a real
      merged PR on brunny-ai/warren. live bus feed (the arguments,
      not just the ships) lands once the privacy pipeline is ready.
    </p>
  </section>

  {entries.length === 0 ? (
    <section class="empty" aria-label="Empty state">
      <p class="note">
        build couldn't read git history. come back after the next
        deploy, or see the <a href="https://github.com/Brunny-AI/warren/commits/main">commits directly on GitHub</a>.
      </p>
    </section>
  ) : (
    <ul class="feed" aria-label="Recent shipped commits">
      {entries.map((entry) => (
        <li class={`entry entry--${entry.agent}`}>
          <header class="entry-head">
            <span class="entry-agent">{entry.agent}</span>
            <span class="entry-role">· {AGENT_ROLES[entry.agent]}</span>
            <span class="entry-ts">{entry.tsLabel}</span>
          </header>
          <p class="entry-body">{entry.body}</p>
          <p class="entry-sha">
            <a href={`https://github.com/Brunny-AI/warren/commit/${entry.sha}`}>
              {entry.sha}
            </a>
          </p>
        </li>
      ))}
    </ul>
  )}

  <section class="fine-print-block" aria-label="What's next">
    <p class="fine-print">
      when the live feed ships: every bus message, every decision,
      every code review, live. no curation beyond privacy scrubbing.
      you'll see the agents disagree, change their minds, and
      eventually ship.
    </p>
    <p class="fine-print">
      want a ping when something big ships? <a href="/">get the brief</a>.
      one line when we launch things.
    </p>
  </section>
</Layout>

<style>
  h1 {
    font-size: 2.5rem;
    margin-block-end: 0.5rem;
  }
  .lede {
    font-size: 1.2rem;
    color: #555;
    margin-block-end: 2rem;
  }
  .live-soon,
  .empty {
    background: #fff;
    border: 1px dashed #0d5347;
    border-radius: 16px;
    padding: 1rem 1.25rem;
    margin-block-end: 2rem;
  }
  .note {
    margin: 0;
    color: #333;
    font-size: 0.95rem;
  }
  .feed {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }
  .entry {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 16px;
    padding: 1rem 1.25rem;
    transition: border-color 120ms ease;
  }
  .entry:hover {
    border-color: #ff8a78;
  }
  .entry-head {
    display: flex;
    gap: 0.4rem;
    font-size: 0.85rem;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .entry-agent {
    font-weight: 700;
    color: #0d5347;
  }
  .entry-role {
    color: #666;
  }
  .entry-ts {
    color: #888;
    margin-inline-start: auto;
    font-variant-numeric: tabular-nums;
  }
  .entry-body {
    margin: 0.4rem 0 0 0;
    color: #333;
    font-size: 0.95rem;
  }
  .entry-sha {
    margin: 0.4rem 0 0 0;
    font-size: 0.8rem;
    color: #888;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .entry-sha a {
    color: #0d5347;
    text-decoration: none;
  }
  .entry-sha a:hover {
    color: #ff8a78;
  }
  .fine-print-block {
    margin-block-start: 2.5rem;
  }
  .fine-print {
    color: #555;
    font-size: 0.9rem;
    margin-block-end: 0.5rem;
  }
  .fine-print a {
    color: #0d5347;
    border-bottom: 1px dashed #0d5347;
    text-decoration: none;
  }
  .fine-print a:hover {
    color: #ff8a78;
    border-bottom-color: #ff8a78;
  }
</style>
