---
import Layout from '../layouts/Layout.astro';
import SignupForm from '../components/SignupForm.astro';

type SignupStatus = { text: string; kind: 'ok' | 'err' } | null;

const SOCIAL = [
  { label: 'Bluesky', href: 'https://bsky.app/profile/brunnybrief.bsky.social' },
  { label: 'GitHub', href: 'https://github.com/Brunny-AI' },
  { label: 'X', href: 'https://x.com/brunnybrief' },
  { label: 'Rednote', href: 'https://www.xiaohongshu.com/' },
];

const signupParam = Astro.url.searchParams.get('signup');
const initialStatus: SignupStatus =
  signupParam === 'saved'
    ? { text: "got it. we'll email you when something ships.", kind: 'ok' }
    : signupParam === 'invalid'
      ? { text: 'invalid email format. try again?', kind: 'err' }
      : signupParam === 'missing'
        ? { text: 'email required. try again?', kind: 'err' }
        : signupParam === 'error'
          ? { text: 'signup failed. try again in a moment?', kind: 'err' }
          : signupParam === 'rate_limited'
            ? { text: 'too many attempts. try again in an hour.', kind: 'err' }
            : null;
---
<Layout
  title="Contact — brunny.ai"
  description="say hi, follow along, get notified"
>
  <section>
    <h2>say hi</h2>
    <p>
      <a href="mailto:info@brunny.ai">info@brunny.ai</a>
    </p>
  </section>

  <section>
    <h2>follow along</h2>
    <ul class="social">
      {SOCIAL.map((s) => (
        <li><a href={s.href}>{s.label}</a></li>
      ))}
    </ul>
  </section>

  <section>
    <h2>stay updated</h2>
    <p>get notified when we launch something new.</p>
    <SignupForm id="contact-signup" source="contact" initialStatus={initialStatus} />
    <p class="disclaimer">
      no spam. we're too busy building.
    </p>
  </section>
</Layout>

<style>
  section {
    margin-block-end: 3rem;
  }
  h2 {
    font-size: 1.5rem;
    margin-block-end: 0.75rem;
  }
  .social {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .disclaimer {
    color: #999;
    font-size: 0.9rem;
  }
</style>
