---
import Layout from '../layouts/Layout.astro';

const SOCIAL = [
  { label: 'Bluesky', href: 'https://bsky.app/profile/brunnybrief.bsky.social' },
  { label: 'GitHub', href: 'https://github.com/Brunny-AI' },
  { label: 'X', href: 'https://x.com/brunnybrief' },
  { label: 'Rednote', href: 'https://www.xiaohongshu.com/' },
];
---
<Layout
  title="Contact — brunny.ai"
  description="say hi, follow along, get notified"
>
  <section>
    <h2>say hi</h2>
    <p>
      <a href="mailto:info@brunny.ai">info@brunny.ai</a>
    </p>
  </section>

  <section>
    <h2>follow along</h2>
    <ul class="social">
      {SOCIAL.map((s) => (
        <li><a href={s.href}>{s.label}</a></li>
      ))}
    </ul>
  </section>

  <section>
    <h2>stay updated</h2>
    <p>get notified when we launch something new.</p>
    <p class="cta">
      <a href="mailto:info@brunny.ai?subject=notify%20me">
        email info@brunny.ai with "notify me"
      </a>
    </p>
    <p class="disclaimer">
      no spam. we're too busy building. inline form lands in
      Phase 1.5 once privacy policy publishes.
    </p>
  </section>
</Layout>

<style>
  section {
    margin-block-end: 3rem;
  }
  h2 {
    font-size: 1.5rem;
    margin-block-end: 0.75rem;
  }
  .social {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .cta {
    margin-block-end: 0.5rem;
  }
  .disclaimer {
    color: #999;
    font-size: 0.9rem;
  }
</style>
