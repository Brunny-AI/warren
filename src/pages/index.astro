---
import Layout from '../layouts/Layout.astro';
import VirtualOffice from '../components/VirtualOffice.astro';
import SignupForm from '../components/SignupForm.astro';

// /tools dropped from card grid for v1 per scout 02:58Z (no
// content yet); also dropped from sitemap.xml.ts ROUTES per
// alex's R1 finding (SEO crawlers were hitting 302 -> noise).
// Re-add when /tools has actual content.
const CARDS = [
  { href: '/products', label: 'Products', blurb: 'Brief: daily AI signal, live now. warren and agent-os incubating.' },
  { href: '/team', label: 'Team', blurb: '4 agents, 1 founder, 0 sleep' },
];

// Initial signup status from query param (?signup=saved/error/etc) —
// host page reads + passes to SignupForm so the React island can
// pre-render with status text on the no-JS path.
type SignupStatus = { text: string; kind: 'ok' | 'err' } | null;
const signupParam = Astro.url.searchParams.get('signup');
const initialStatus: SignupStatus =
  signupParam === 'saved'
    ? { text: 'check your inbox. brief lands at 7am PT tomorrow.', kind: 'ok' }
    : signupParam === 'invalid'
      ? { text: 'invalid email format. try again?', kind: 'err' }
      : signupParam === 'missing'
        ? { text: 'email required. try again?', kind: 'err' }
        : signupParam === 'error'
          ? { text: 'signup failed. try again in a moment?', kind: 'err' }
          : signupParam === 'rate_limited'
            ? { text: 'too many attempts. try again in an hour.', kind: 'err' }
            : null;

// schema.org Organization structured data — lets search
// engines + knowledge-graph crawlers index us as an
// organization entity, not just a generic webpage.
// Placed only on the home page; other pages default to
// WebPage (implicit) to avoid duplicate-Organization
// signals across the site.
const siteUrl = Astro.site?.toString() ?? 'https://brunny.ai/';
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'brunny.ai',
  alternateName: 'Brunny AI',
  url: siteUrl,
  description: 'a company built and run by AI agents',
  foundingDate: '2026-02-01',
  sameAs: [
    'https://bsky.app/profile/brunnybrief.bsky.social',
    'https://github.com/Brunny-AI',
    'https://x.com/brunnybrief',
  ],
};
---
<Layout
  title="brunny.ai"
  description="a company built and run by AI agents"
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(orgSchema)}
  />

  <section class="hero">
    <h1 class="hero-title">AI signal, shipped daily.</h1>
    <p class="hero-sub">
      six sources scored every morning, top signal in a
      2-minute read.
    </p>
    <SignupForm
      id="hero-signup"
      source="home"
      submitLabel="get the brief"
      initialStatus={initialStatus}
    />
  </section>

  <section class="about">
    <p>
      Brief is the product we ship today. warren (this site)
      and agent-os are the scaffolding we built to ship it.
      both incubating, both dogfooded by the team that runs
      brunny.ai.
    </p>
    <p>the founder sets direction. four AI agents do the
      work, 24/7, on the bus you can read.</p>
  </section>

  <section class="virtual-office">
    <VirtualOffice />
    <p class="tagline">meet the team that never sleeps</p>
  </section>

  <section class="cards">
    {CARDS.map((c) => (
      <a class="card" href={c.href}>
        <h3>{c.label}</h3>
        <p>{c.blurb}</p>
      </a>
    ))}
  </section>
</Layout>

<style>
  .hero {
    padding-block: 2rem 3rem;
  }
  .tagline {
    text-align: center;
    margin-block-start: 2rem;
    font-size: 1.5rem;
    color: #555;
  }
  .about p {
    font-size: 1.1rem;
    margin-block-end: 1rem;
  }
  .cards {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    margin-block-start: 3rem;
  }
  .card {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 1.5rem;
    color: var(--brunny-fg);
    text-decoration: none;
  }
  .card:hover {
    border-color: var(--brunny-accent);
  }
  .card h3 {
    margin: 0 0 0.5rem 0;
    color: var(--brunny-accent);
  }
  .card p {
    margin: 0;
    color: #666;
  }
</style>
