---
const LINKS = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/team', label: 'Team' },
  { href: '/tools', label: 'Tools' },
  { href: '/contact', label: 'Contact' },
];
---
<header>
  <nav>
    <a href="/" class="brand">brunny.ai</a>
    <ul>
      {LINKS.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid #eee;
    padding-block: 1rem;
  }
  nav {
    max-width: var(--brunny-max-width);
    margin-inline: auto;
    padding-inline: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    font-weight: bold;
    font-size: 1.2rem;
  }
  ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
</style>
