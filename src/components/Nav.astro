---
import NavReact from './NavReact';

const currentPath = Astro.url.pathname;
---
<header>
  <a href="/" class="brand">brunny.ai</a>
  <NavReact currentPath={currentPath} client:only="react" />
</header>

<style>
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1rem;
    padding-inline: 1rem;
    max-width: 960px;
    margin-inline: auto;
  }
  .brand {
    font-weight: 700;
    font-size: 1.2rem;
    color: #1f3a36; /* theme colorTextBase */
    text-decoration: none;
  }
</style>
