---
/**
 * SignupForm — host wrapper for SignupFormReact island.
 *
 * Used on /products and /contact. Astro SSR's the React island
 * (via client:load, NOT client:only) so the rendered HTML
 * contains a native <form action="/api/signup" method="post">
 * for no-JS visitors. On hydration, antd's onFinish handler
 * intercepts via preventDefault and POSTs JSON.
 *
 * Server-side query-param to initialStatus translation lives
 * in the host page (products.astro / contact.astro).
 */
import SignupFormReact from './SignupFormReact';

interface Props {
  readonly id?: string;
  readonly source?: string;
  readonly submitLabel?: string;
  readonly initialStatus?: { text: string; kind: 'ok' | 'err' } | null;
  readonly emailPlaceholder?: string;
  readonly successText?: string;
}

const {
  id = 'signup',
  source = 'products',
  submitLabel = 'notify me',
  initialStatus = null,
  emailPlaceholder,
  successText,
} = Astro.props;
---
<SignupFormReact
  id={id}
  source={source}
  submitLabel={submitLabel}
  initialStatus={initialStatus}
  emailPlaceholder={emailPlaceholder}
  successText={successText}
  client:load
/>
