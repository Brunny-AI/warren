---
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';

interface Props {
  readonly title: string;
  readonly description?: string;
  /**
   * Override the og:type. Defaults to 'website' for landing
   * pages; pass 'article' for future announcement pages.
   */
  readonly ogType?: 'website' | 'article';
}

const {
  title,
  description = 'brunny.ai',
  ogType = 'website',
} = Astro.props;

// Canonical + social URLs derive from astro.config.mjs `site`
// + the current pathname. Absolute URLs are required by OG /
// Twitter Card spec — relative URLs silently don't render.
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.toString();

// Default OG image. The actual PNG lands in a follow-up PR
// (design asset dependency). Until then, scrapers fall back
// to favicon or show no preview; the meta tag path is future-
// proof so the asset swap is one-line.
const ogImage = Astro.site
  ? new URL('/og-default.png', Astro.site).toString()
  : '/og-default.png';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph (Facebook, LinkedIn, Bluesky, Slack, etc.) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="brunny.ai" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /*
   * Cartoon-theme baseline for non-React (slot) content.
   * antd ConfigProvider handles theme inside React islands;
   * these are the values for raw .astro page content. Hex
   * values mirror src/lib/theme.ts cartoonTheme.token —
   * single-source-of-truth lives in theme.ts but raw CSS
   * can't import .ts at runtime so values duplicate here.
   */
  html,
  body {
    margin: 0;
    padding: 0;
    background: #f5e6d0; /* cartoonTheme.token.colorBgBase */
    color: #1f3a36; /* cartoonTheme.token.colorTextBase */
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    line-height: 1.6;
  }
  main {
    max-width: 960px;
    margin-inline: auto;
    padding-block: 2rem;
    padding-inline: 1rem;
  }
  a {
    color: #0d5347; /* cartoonTheme.token.colorPrimary */
    text-decoration: none;
  }
  a:hover {
    text-decoration: underline;
  }
</style>
