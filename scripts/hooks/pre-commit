#!/usr/bin/env bash
# Pre-commit hook: block direct commits to main + validate
# branch naming. Install: cp scripts/hooks/pre-commit .git/hooks/

set -euo pipefail

branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"

if [[ "${branch}" == "main" ]]; then
  echo "ERROR: Direct commits to main are blocked." >&2
  echo "Create a branch first:" >&2
  echo "  git checkout -b {agent}/{description}" >&2
  echo "See .claude/rules/pr-workflow.md" >&2
  exit 1
fi

# Validate branch naming: must match {agent}/{description}
if [[ -n "${branch}" ]] \
  && ! echo "${branch}" \
    | grep -qE '^[a-z][-a-z0-9]*/[a-z][-a-z0-9]*$'; then
  echo "WARNING: Branch '${branch}' doesn't match" >&2
  echo "the {agent}/{description} convention." >&2
fi

# Em-dash guard on staged user-facing files.
# Per feedback_no_em_dashes rule: em-dashes (—, ——) are an AI
# fingerprint, banned from published content. Source files under
# src/ (Astro pages, layouts, components), docs/ (repo docs),
# and root-level README.md + CONTRIBUTING.md + CLAUDE.md (these
# render on GitHub and land in external-contributor eyes) all
# ship to readers. Commit messages + code comments + non-scoped
# markdown (e.g. migrations/*.md, scratch/*.md) stay internal.
#
# Root scope is enumerated (not '*.md' wildcard) because git
# pathspec '*.md' crosses directory boundaries and pulls in
# scratch/internal markdown. Add new root-level user-facing
# *.md files to the pathspec list when needed.
#
# Scans `git diff --cached` for em-dash additions in scope files.
# If the line is inside a // or /* ... */ comment, skip. Non-
# comment lines with em-dash block the commit with --no-verify
# as the override path for intentional exceptions.
dash_hits=$(
  git diff --cached --no-color --unified=0 --diff-filter=AM \
    -- 'src/**' 'docs/**' 'README.md' 'CONTRIBUTING.md' 'CLAUDE.md' \
    | awk '
      /^\+\+\+ / { file=$2; sub("^b/", "", file); next }
      /^@@ / { in_hunk=1; next }
      in_hunk && /^\+/ {
        line=$0
        # Skip comment lines (// or /* or leading *)
        if (line ~ /^\+[[:space:]]*(\/\/|\/\*|\*)/) next
        if (line ~ /—/) print file ": " substr(line, 2)
      }
    '
)

if [[ -n "${dash_hits}" ]]; then
  echo "ERROR: em-dash (—) in staged user-facing content:" >&2
  echo "${dash_hits}" >&2
  echo "" >&2
  echo "Per feedback_no_em_dashes: em-dashes are an AI fingerprint." >&2
  echo "Replace with period, comma, or sentence restructure." >&2
  echo "Code comments are exempt (// and /* are skipped)." >&2
  echo "Override intentionally: git commit --no-verify" >&2
  exit 1
fi
